<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/services.xsd">
    <description>ProductManagement Services</description>
    <vendor>Apache OFBiz</vendor>
    <version>1.0</version>

    <!-- 1. Find Product Service -->
    <service name="findProduct" engine="groovy"
             location="component://ProductManagement/groovyScripts/ProductServices.groovy" invoke="findProduct" auth="true">
        <description>Search for products using name, id, category, price range, and feature filters</description>
        <attribute name="productId" type="String" mode="IN" optional="true"/>
        <attribute name="productName" type="String" mode="IN" optional="true"/>
        <attribute name="productCategoryId" type="String" mode="IN" optional="true"/>
        <attribute name="minPrice" type="BigDecimal" mode="IN" optional="true"/>
        <attribute name="maxPrice" type="BigDecimal" mode="IN" optional="true"/>
        <attribute name="productFeatureId" type="String" mode="IN" optional="true"/>
        <attribute name="productFeatureTypeId" type="String" mode="IN" optional="true"/>
        <attribute name="featureDescription" type="String" mode="IN" optional="true"/>
        <attribute name="productList" type="List" mode="OUT" optional="true"/>
    </service>

    <!-- 2. Create Product Service -->
    <service name="createProduct" engine="groovy"
             location="component://ProductManagement/groovyScripts/ProductServices.groovy" invoke="createProduct" auth="true">
        <description>Create a new product (Product + Category member + List Price)</description>
        <attribute name="productName" type="String" mode="IN" optional="false"/>
        <attribute name="productCategoryId" type="String" mode="IN" optional="false"/>
        <attribute name="price" type="BigDecimal" mode="IN" optional="false"/>
        <attribute name="productId" type="String" mode="OUT" optional="true"/>
    </service>

    <!-- 3. Update Product Service -->
    <service name="updateProduct" engine="groovy"
             location="component://ProductManagement/groovyScripts/ProductServices.groovy" invoke="updateProduct" auth="true">
        <description>Update product price and feature associations</description>
        <attribute name="productId" type="String" mode="IN" optional="false"/>
        <attribute name="price" type="BigDecimal" mode="IN" optional="true"/>
        <attribute name="productFeatureId" type="String" mode="IN" optional="true"/>
        <attribute name="productIdOut" type="String" mode="OUT" optional="true"/>
    </service>

    <!-- 4. Associate Variant Product to Virtual Product Service -->
    <service name="assocProductToVirtual" engine="groovy"
             location="component://ProductManagement/groovyScripts/ProductServices.groovy" invoke="assocProductToVirtual" auth="true">
        <description>Establish a virtual relationship between a variant product and a virtual product</description>
        <attribute name="productId" type="String" mode="IN" optional="false"/>
        <attribute name="virtualProductId" type="String" mode="IN" optional="false"/>
        <attribute name="fromDate" type="java.sql.Timestamp" mode="OUT" optional="true"/>
    </service>

    <!-- 5. Update Product Variant Relationship Service -->
    <service name="updateProductVariant" engine="groovy"
             location="component://ProductManagement/groovyScripts/ProductServices.groovy" invoke="updateProductVariant" auth="true">
        <description>Modify an existing variant relationship</description>
        <attribute name="productId" type="String" mode="IN" optional="false"/>
        <attribute name="virtualProductId" type="String" mode="IN" optional="false"/>
        <attribute name="thruDate" type="java.sql.Timestamp" mode="IN" optional="true"/>
        <attribute name="sequenceNum" type="Long" mode="IN" optional="true"/>
        <attribute name="quantity" type="BigDecimal" mode="IN" optional="true"/>
    </service>
</services>