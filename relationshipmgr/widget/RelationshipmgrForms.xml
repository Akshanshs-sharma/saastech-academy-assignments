<forms xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://ofbiz.apache.org/Widget-Form" xsi:schemaLocation="http://ofbiz.apache.org/Widget-Form http://ofbiz.apache.org/dtds/widget-form.xsd">

        <!-- 1. The Party Dashboard List -->
    <form name="ListRmParties" type="list" list-name="parties" paginate-target="main"
        default-title-style="tableheadcol" default-widget-style="tabletextcol" style="basic-table hover-bar">
        <actions>
            <entity-condition entity-name="RmParty" list="parties">
                <order-by field-name="partyId"/>
            </entity-condition>
        </actions>
        <row-actions>
            <!-- Call the external Groovy script for row processing -->
            <script location="component://relationshipmgr/groovyScripts/GetPartyDetails.groovy"/>
        </row-actions>
        
        <field name="partyId" title="Party ID"><display/></field>
        <field name="partyTypeId" title="Type"><display/></field>
        <field name="partyName" title="Name"><display/></field>
        <field name="rolesList" title="Assigned Roles"><display/></field>
        <field name="contactsList" title="Contact Information"><display/></field>
    </form>


    <!-- 2. Create Person Form -->
    <form name="AddRmPerson" type="single" target="createRmPerson" title="Create Person" style="basic-form">
        <field name="partyTypeId"><hidden value="PERSON"/></field>
        <field name="firstName" title="First Name" widget-style="required"><text size="30" placeholder="First Name"/></field>
        <field name="lastName" title="Last Name" widget-style="required"><text size="30" placeholder="Last Name"/></field>
        <field name="birthDate" title="Birth Date"><date-time type="date"/></field>
        <field name="submitButton" title="Create"><submit button-type="button"/></field>
    </form>

    <!-- 3. Create Organization Form -->
    <form name="AddRmOrganization" type="single" target="createRmOrganization" title="Create Organization" style="basic-form">
        <field name="partyTypeId"><hidden value="ORGANIZATION"/></field>
        <field name="organizationName" title="Organization Name" widget-style="required"><text size="40" placeholder="e.g. Department of Engineering"/></field>
        <field name="submitButton" title="Create"><submit button-type="button"/></field>
    </form>

    <!-- 4. Assign Role Form -->
    <form name="AddRmPartyRole" type="single" target="createRmPartyRole" title="Assign Role" style="basic-form">
        <field name="partyId" title="Party ID" widget-style="required">
            <drop-down allow-empty="false">
                <entity-options entity-name="RmParty" key-field-name="partyId" description="${partyId}">
                    <entity-order-by field-name="partyId"/>
                </entity-options>
            </drop-down>
        </field>
        <field name="roleTypeId" title="Role" widget-style="required">
            <drop-down allow-empty="false">
                <entity-options entity-name="RmRoleType" key-field-name="roleTypeId" description="${description}">
                    <entity-order-by field-name="description"/>
                </entity-options>
            </drop-down>
        </field>
        <field name="submitButton" title="Assign Role"><submit button-type="button"/></field>
    </form>

</forms>
