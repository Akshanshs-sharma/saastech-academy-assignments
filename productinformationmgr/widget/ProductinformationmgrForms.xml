    <form name="FindProduct" type="single" target="FindProduct" default-entity-name="PimProduct">
        <auto-fields-entity entity-name="PimProduct" default-field-type="find"/>
        <field name="noConditionFind"><hidden value="Y"/></field>
        <field name="submitButton" title="Find"><submit button-type="button"/></field>
    </form>
    <form name="ListProducts" type="list" list-name="listIt" target="UpdateProduct" default-entity-name="PimProduct">
        <actions>
            <set field="entityName" value="PimProduct"/>
            <service service-name="performFind" result-map="result" result-map-list="listIt">
                <field-map field-name="inputFields" from-field="parameters"/>
                <field-map field-name="entityName" from-field="entityName"/>
                <field-map field-name="viewIndex" from-field="viewIndex"/>
                <field-map field-name="viewSize" from-field="viewSize"/>
            </service>
        </actions>
        <auto-fields-entity entity-name="PimProduct" default-field-type="display"/>
        <field name="productId" widget-style="buttontext">
            <hyperlink description="${productId}" target="EditProduct">
                <parameter param-name="productId"/>
            </hyperlink>
        </field>
        <field name="deleteLink" title=" " widget-style="buttontext">
            <hyperlink description="Delete" target="deletePimProduct" also-hidden="false">
                <parameter param-name="productId"/>
            </hyperlink>
        </field>
    </form>
    <form name="EditProduct" type="single" target="createPimProduct" default-entity-name="PimProduct">
        <alt-target use-when="product!=null" target="updatePimProduct"/>
        <actions>
            <entity-one entity-name="PimProduct" value-field="product"/>
        </actions>
        <auto-fields-entity entity-name="PimProduct" default-field-type="edit"/>
        <field name="productId" use-when="product!=null"><display/></field>
        <field name="productId" use-when="product==null"><text/></field>
        <field name="submitButton" title="Save"><submit button-type="button"/></field>
    </form>

